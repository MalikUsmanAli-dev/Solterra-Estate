# Copy this file to .env and fill in your EmailJS credentials to enable
# live email delivery from the Reservations form. Without these, the form
# still validates and shows a success state, but no email is sent.
# https://www.emailjs.com/

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
